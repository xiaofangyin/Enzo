<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <com.enzo.commonlib.widget.timeclock.SHTimeClock
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="30dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="horizontal">

            <com.enzo.commonlib.widget.togglebutton.FlToggleButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <com.enzo.commonlib.widget.togglebutton.FLSwitchButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="40dp" />
        </LinearLayout>

        <com.enzo.commonlib.widget.flickeringtextview.FlickeringTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="欢迎\nWelcome"
            android:textColor="#f3f"
            android:textSize="30sp"
            app:flickeringColor="#FFFF00" />
    </LinearLayout>
</android.support.constraint.ConstraintLayout>