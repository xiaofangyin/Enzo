<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <com.ifenglian.commonlib.widget.view.timeclock.SHTimeClock
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="30dp" />

        <com.ifenglian.commonlib.widget.view.togglebutton.FlToggleButton
            android:layout_width="51dp"
            android:layout_height="30dp"
            android:layout_margin="20dp" />

        <com.ifenglian.commonlib.widget.view.flickeringtextview.FlickeringTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="欢迎\nWelcome"
            android:textColor="#f3f"
            android:textSize="30sp"
            app:flickeringColor="#FFFF00" />
    </LinearLayout>
</android.support.constraint.ConstraintLayout>