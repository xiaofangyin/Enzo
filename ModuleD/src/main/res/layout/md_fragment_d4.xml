<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <Button
            android:id="@+id/btn_structure"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="数据结构" />

        <Button
            android:id="@+id/btn_img_single_choose"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="选择照片(单选)" />

        <Button
            android:id="@+id/btn_img_multiple_choose"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="选择照片(多选)" />

        <Button
            android:id="@+id/btn_bar_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="条形码扫描" />

        <Button
            android:id="@+id/btn_qr_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="二维码扫描" />

        <Button
            android:id="@+id/btn_picker_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="日期选择" />

        <Button
            android:id="@+id/btn_calendar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="日历" />

        <Button
            android:id="@+id/btn_meizu_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="魅族轮播图" />

        <Button
            android:id="@+id/btn_notification"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="消息通知" />
    </LinearLayout>
</ScrollView>
