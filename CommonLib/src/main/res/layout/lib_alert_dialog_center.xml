<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_alert_view_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/lib_alert_dialog_shape_content_bg"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tv_alert_dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:layout_marginLeft="18dp"
        android:layout_marginRight="18dp"
        android:gravity="center"
        android:textColor="#000000"
        android:textSize="18sp"
        android:text="确定"
        android:textStyle="bold" />

    <View
        android:id="@+id/v_alert_dialog_line1"
        android:layout_width="fill_parent"
        android:layout_height="0.5dp"
        android:background="#cacaca"
        android:visibility="invisible" />

    <LinearLayout
        android:id="@+id/ll_alert_dialog_content_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_alert_dialog_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:layout_marginLeft="12dp"
            android:layout_marginRight="12dp"
            android:gravity="center"
            android:text="确定退出吗?"
            android:layout_marginTop="3dp"
            android:textColor="#000000"
            android:textSize="18sp" />
    </LinearLayout>

    <View
        android:id="@+id/alert_dialog_line2"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#cacaca" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_alert_dialog_cancel"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="@drawable/lib_alert_dialog_selector_button_left"
            android:gravity="center"
            android:text="取消"
            android:textColor="@drawable/lib_selector_text_color_999"
            android:textSize="18sp" />

        <View
            android:id="@+id/v_alert_dialog_line3"
            android:layout_width="0.5dp"
            android:layout_height="match_parent"
            android:background="#cacaca" />

        <TextView
            android:id="@+id/tv_alert_dialog_confirm"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="@drawable/lib_alert_dialog_selector_button_right"
            android:gravity="center"
            android:text="确定"
            android:textColor="@drawable/lib_selector_text_color_blue"
            android:textSize="18sp" />
    </LinearLayout>
</LinearLayout>
