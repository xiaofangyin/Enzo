<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.ifenglian.commonlib.widget.view.speedtest.SRSpeedTestView
            android:id="@+id/speed_test_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_margin="20dp" />

        <com.ifenglian.commonlib.widget.view.danmu.FLDanMuView
            android:id="@+id/fl_dan_mu"
            android:layout_width="match_parent"
            android:layout_height="110dp" />

        <LinearLayout
            android:id="@+id/sr_ll_edit_dan_mu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="right"
            android:layout_margin="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/sr_iv_edit_dan_mu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="6dp"
                android:src="@mipmap/lib_tool_edit_dan_mu" />

            <ImageView
                android:id="@+id/sr_iv_show_dan_mu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="6dp"
                android:src="@mipmap/lib_tool_close_dan_mu" />
        </LinearLayout>
    </LinearLayout>
</android.support.constraint.ConstraintLayout>