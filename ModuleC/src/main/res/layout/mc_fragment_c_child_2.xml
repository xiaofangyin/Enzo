<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/supply_height_current_height"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/color_green"
            android:textSize="40dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="cm"
            android:textColor="@color/color_green"
            android:textSize="12sp" />
    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp">

        <com.enzo.commonlib.widget.boheruler.RulerView
            android:id="@+id/supply_height_ruler"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:background="#F1FDFB"
            app:lineColor="@color/color_green_light"
            app:lineMaxHeight="46dp"
            app:lineMidHeight="34dp"
            app:lineMinHeight="26dp"
            app:lineSpaceWidth="12dp"
            app:lineWidth="2dp"
            app:maxValue="230.0"
            app:minValue="70.0"
            app:perValue="0.1"
            app:selectorValue="170.0"
            app:textColor="@color/color_green_light"
            app:textMarginTop="16dp"
            app:textSize="16sp" />

        <View
            android:layout_width="2dp"
            android:layout_height="54dp"
            android:layout_centerHorizontal="true"
            android:background="@color/color_green" />
    </RelativeLayout>
</LinearLayout>
